# ============================================================
# EditorConfig — 모든 레포 공통 (IDE 무관 포맷 통일)
# ============================================================
# VS Code, IntelliJ, vim 등 대부분 에디터가 자동 인식합니다.
# VS Code는 "EditorConfig for VS Code" 확장 필요.
# ============================================================

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 120

[*.{ts,tsx,js,jsx,json,yml,yaml,css,html}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[Makefile]
indent_style = tab
