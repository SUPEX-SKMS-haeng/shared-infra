services:
  gateway:
    image: traefik:v3.1
    command: --api.insecure=true --providers.docker
    volumes:
      - ./traefik.yml:/etc/traefik/traefik.yml
      - ./traefik_dynamic_conf.yml:/etc/config/dynamic_conf.yml
      - ${DATA_PATH}/logs/gateway:/var/log/traefik
    environment:
      - MY_HOST=host.docker.internal
    ports:
      - "8000:8000" # Traefik endpoint
      - "18080:8080" # Traefik dashboard
