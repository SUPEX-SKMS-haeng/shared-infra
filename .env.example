# Application
ENVIRONMENT=local
DATA_PATH=/directories/.../data
MASTER_KEY=""

# Database
DB_ENGINE=postgresql
DB_PORT=5432
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=5
DB_POOL_RECYCLE=1500
DB_POOL_TIMEOUT=10
DB_HOST=127.0.0.1
DB_NAME=dev
DB_USER=user
DB_PASSWORD="password"

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_ACCESS_KEY=""
REDIS_USE_SSL=False

# Azure OpenAI
LLM_CONFIG_SOURCE="env"
AZURE_OPENAI_API_KEY= ""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_DEPLOYMENT= ""

# Arize Phoenix
PHOENIX_ENABLED=False

# Milvus MinIO
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""

# Milvus (Vector Database) - 공용 설정
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=""
MILVUS_PASSWORD=""
MILVUS_DB_NAME=default

# MCP
## Weather
OPENWEATHER_API_URL=""
OPENWEATHER_API_KEY=""
## Naver
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
## Notion Scraper Tool
### Tool 설정 (LLM이 인식할 이름과 설명)
NOTION_SCRAPER_TOOL_NAME=scrape_notion_page
NOTION_SCRAPER_TOOL_DESCRIPTION=LangChain 공식 문서 조회 도구. LangChain 사용법, API 레퍼런스, 예시 코드를 제공합니다. create_agent, LCEL, chains, tools, prompts, callbacks 등 LangChain의 모든 기능에 대한 상세 설명과 코드 예제를 검색할 수 있습니다. 사용 방법: action='toc'(목차), action='section'(특정 섹션), action='search'(키워드 검색)
NOTION_SCRAPER_DEFAULT_URL=https://your-notion-page-url
NOTION_SCRAPER_COLLECTION_NAME=langchain_docs
NOTION_SCRAPER_CACHE_DIR_NAME=langchain_docs
